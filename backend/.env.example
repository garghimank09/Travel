# PostgreSQL (PgAdmin / database name: Travel)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/Travel

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# AI: ollama (default) | openai | auto
#   auto = use OpenAI if OPENAI_API_KEY is set, otherwise Ollama
AI_PROVIDER=ollama

# Ollama (local) — run: ollama serve  then  ollama pull <OLLAMA_MODEL>
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (only if AI_PROVIDER=openai or auto with key set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# API response cache TTL in seconds (0 to disable)
CACHE_TTL_SECONDS=60
